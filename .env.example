# LLM provider: openai, anthropic, or xai
LLM_PROVIDER=xai

# API keys (only the selected provider's key is required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
XAI_API_KEY=xai-...

# Model names (defaults shown)
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-20250514
XAI_MODEL=grok-4-1-fast-reasoning

# Embedding model (always OpenAI)
EMBEDDING_MODEL=text-embedding-3-small

# RAG settings
RESOURCES_DIR=resources
CHROMA_PERSIST_DIR=.chroma_db
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# LangSmith observability (read directly by LangChain)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=health-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
