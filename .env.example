# API keys
VOYAGE_API_KEY=pa-...
ANTHROPIC_API_KEY=sk-ant-...
XAI_API_KEY=xai-...
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/health_agent

# Model names (defaults shown)
TRUSTED_XAI_MODEL=grok-4-1-fast-reasoning
UNRESTRICTED_XAI_MODEL=grok-4-1-fast-reasoning
ANTHROPIC_SYNTHESIS_MODEL=claude-sonnet-4-20250514

# Embedding + reranker (Voyage AI)
EMBEDDING_MODEL=voyage-3.5
EMBEDDING_DIMENSIONS=1024
RERANKER_MODEL=rerank-2.5

# Trusted X accounts used by the restricted Grok search stage
TRUSTED_X_ACCOUNTS=["helios_movement","grimhood","aestheticprimal","hubermanlab","foundmyfitness","outdoctrination"]

# RAG settings
RESOURCES_DIR=resources
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# LangSmith observability (read directly by LangChain)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=health-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Clerk auth
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Shared secret used to authenticate the Next.js webhook relay
BACKEND_WEBHOOK_SECRET=
