# LLM provider: openai, anthropic, or xai
HEALTH_LLM_PROVIDER=xai

# API keys (only the selected provider's key is required)
HEALTH_OPENAI_API_KEY=sk-...
HEALTH_ANTHROPIC_API_KEY=sk-ant-...
HEALTH_XAI_API_KEY=xai-...

# Model names (defaults shown)
HEALTH_OPENAI_MODEL=gpt-4o-mini
HEALTH_ANTHROPIC_MODEL=claude-sonnet-4-20250514
HEALTH_XAI_MODEL=grok-4-1-fast-reasoning

# Embedding model (always OpenAI)
HEALTH_EMBEDDING_MODEL=text-embedding-3-small

# RAG settings
HEALTH_RESOURCES_DIR=resources
HEALTH_CHROMA_PERSIST_DIR=.chroma_db
HEALTH_CHUNK_SIZE=1000
HEALTH_CHUNK_OVERLAP=200
